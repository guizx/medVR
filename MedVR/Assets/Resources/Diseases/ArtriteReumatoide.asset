--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4914806f9ea8b5541b2d13621845ac3c, type: 3}
  m_Name: ArtriteReumatoide
  m_EditorClassIdentifier: Assembly-CSharp::DiseaseData
  DiseaseName: Artrite Reumatoide
  DiseaseTriage:
  - "Relata desconforto persistente em m\xE3os e punhos que dificulta movimentos
    habituais."
  EmergencyCode: 1
  Phrases:
  - PhraseSFX: {fileID: 8300000, guid: dab48637e89fbac45b155452f8c63307, type: 3}
    Phrase: "Toda manh\xE3 \xE9 uma luta, doutor. Quando acordo, minhas m\xE3os est\xE3o
      travadas, levo quase uma hora para conseguir mexer os dedos direito."
    Options:
    - SymptomName: Rigidez matinal prolongada
      IsCorrect: 1
    - SymptomName: Fraqueza muscular matinal
      IsCorrect: 0
    - SymptomName: "C\xE3ibras noturnas"
      IsCorrect: 0
  - PhraseSFX: {fileID: 8300000, guid: fb82aa598519a8c4e8a9b965479bd84d, type: 3}
    Phrase: "O problema \xE9 nos dois lados, viu? As juntas dos dedos das duas m\xE3os
      doem e incham do mesmo jeito."
    Options:
    - SymptomName: Artrite gotosa
      IsCorrect: 0
    - SymptomName: "Poliartrite sim\xE9trica"
      IsCorrect: 1
    - SymptomName: "Les\xE3o por esfor\xE7o repetitivo"
      IsCorrect: 0
  - PhraseSFX: {fileID: 8300000, guid: 67940168a23a4684aaee975b25dbfdf0, type: 3}
    Phrase: "Com o passar dos anos, meus dedos foram entortando, est\xE3o ficando
      com esse formato torto, sabe?"
    Options:
    - SymptomName: Deformidades articulares
      IsCorrect: 1
    - SymptomName: "Fraturas \xF3sseas espont\xE2neas"
      IsCorrect: 0
    - SymptomName: Atrofia muscular distal
      IsCorrect: 0
