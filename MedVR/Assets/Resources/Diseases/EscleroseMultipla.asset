  m_Name: EscleroseMultipla
  m_EditorClassIdentifier: Assembly-CSharp::DiseaseData
  DiseaseName: "Esclerose M\xFAltipla"
  DiseaseTriage:
  - "Paciente apresenta epis\xF3dios recorrentes de vertigem, al\xE9m de queixa de
    turva\xE7\xE3o visual unilateral de in\xEDcio s\xFAbito. "
  EmergencyCode: 2
  Phrases:
  - PhraseSFX: {fileID: 8300000, guid: 6dcf8eba8e505a0418eaf3477c817bc8, type: 3}
    Phrase: "Doutor, as vezes o mundo gira todo de repente, perco o equil\xEDbrio
      e me sinto muito zonzo."
    Options:
    - SymptomName: "Press\xE3o baixa"
      IsCorrect: 0
    - SymptomName: Vertigem
      IsCorrect: 1
    - SymptomName: Fadiga
      IsCorrect: 0
  - PhraseSFX: {fileID: 8300000, guid: 2fab2e7b1514fda48b7cc8015aee9cea, type: 3}
    Phrase: "Sinto uns formigamentos estranhos nas pernas e nos bra\xE7os, como se
      fossem alfinetadas que n\xE3o param."
    Options:
    - SymptomName: Parestesias
      IsCorrect: 1
    - SymptomName: "Defici\xEAncia de vitamina B12"
      IsCorrect: 0
    - SymptomName: "Dor \xF3ssea"
      IsCorrect: 0
  - PhraseSFX: {fileID: 8300000, guid: 64819d62eb1b7d74e91a85d3032f0ad7, type: 3}
    Phrase: "De repente, minha vis\xE3o no olho esquerdo ficou emba\xE7ada, parecia
      que eu estava olhando atrav\xE9s de uma n\xE9voa."
    Options:
    - SymptomName: "Neurite \xF3ptica"
      IsCorrect: 1
    - SymptomName: Conjutivite
      IsCorrect: 0
    - SymptomName: Catarata
      IsCorrect: 0
