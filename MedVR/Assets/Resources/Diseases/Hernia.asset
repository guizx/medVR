--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 4914806f9ea8b5541b2d13621845ac3c, type: 3}
  m_Name: Hernia
  m_EditorClassIdentifier: Assembly-CSharp::DiseaseData
  DiseaseName: Hernia
  DiseaseTriage:
  - "Queixa de inc\xF4modo em regi\xE3o espec\xEDfica do abd\xF4men/virilha ap\xF3s
    realizar esfor\xE7o."
  Phrases:
  - PhraseSFX: {fileID: 8300000, guid: 44fff83921bce304dbfca84bb37a5078, type: 3}
    Phrase: "Doutor, senti um caro\xE7o aqui na minha virilha, parece que ele aparece
      quando eu fa\xE7o algum esfor\xE7o ou carrego peso.\r\n"
    Options:
    - SymptomName: "Lipoma subcut\xE2neo"
      IsCorrect: 0
    - SymptomName: "Protuber\xE2ncia inguinal"
      IsCorrect: 1
    - SymptomName: Linfonodomegalia
      IsCorrect: 0
  - PhraseSFX: {fileID: 8300000, guid: 385ca99dd01ec8648b548b55e3d21f33, type: 3}
    Phrase: "Quando eu tento levantar algo pesado, sinto uma dor aguda exatamente
      onde est\xE1 esse caro\xE7o."
    Options:
    - SymptomName: "Dor neurop\xE1tica"
      IsCorrect: 0
    - SymptomName: "Dor localizada ao esfor\xE7o"
      IsCorrect: 1
    - SymptomName: "Dor irradiada para o test\xEDculo"
      IsCorrect: 0
  - PhraseSFX: {fileID: 8300000, guid: e0614bc0566995a4385d836a618d3069, type: 3}
    Phrase: "O curioso \xE9 que, quando eu deito e relaxo, esse caro\xE7o simplesmente
      desaparece, como se voltasse para dentro."
    Options:
    - SymptomName: Redutibilidade da massa
      IsCorrect: 1
    - SymptomName: "Encarcera\xE7\xF5es recorrentes"
      IsCorrect: 0
    - SymptomName: "Inflama\xE7\xE3o d\xE9rmica"
      IsCorrect: 0
