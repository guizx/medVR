  m_Script: {fileID: 11500000, guid: 4914806f9ea8b5541b2d13621845ac3c, type: 3}
  m_Name: Dengue
  m_EditorClassIdentifier: Assembly-CSharp::DiseaseData
  DiseaseName: Dengue
  Phrases:
  - PhraseSFX: {fileID: 8300000, guid: 0b67b8ee73b483b469cff5ef0dece9ed, type: 3}
    Phrase: "Doutor, eu n\xE3o estou aguentando... parece que tem uma press\xE3o
      insuport\xE1vel bem atr\xE1s dos meus olhos."
    Options:
    - SymptomName: "Vermelhid\xE3o ocular"
      IsCorrect: 0
    - SymptomName: Dor retro-orbital
      IsCorrect: 1
    - SymptomName: Fotofobia intensa
      IsCorrect: 0
  - PhraseSFX: {fileID: 8300000, guid: ded22a4d520563c42bc93a403c263517, type: 3}
    Phrase: "Tamb\xE9m reparei hoje de manh\xE3 que meu corpo est\xE1 todo manchado
      de vermelho. N\xE3o co\xE7a, s\xF3 est\xE1 manchado."
    Options:
    - SymptomName: Exantema maculopapular
      IsCorrect: 1
    - SymptomName: "Urtic\xE1ria al\xE9rgica"
      IsCorrect: 0
    - SymptomName: Hematomas por trauma
      IsCorrect: 0
  - PhraseSFX: {fileID: 8300000, guid: d0773426a2645794680dcfe3791e7caa, type: 3}
    Phrase: "A febre subiu de repente ontem \xE0 noite. Estou com calafrios o tempo
      todo."
    Options:
    - SymptomName: Febre vespertina prolongada
      IsCorrect: 0
    - SymptomName: "Febre alta de in\xEDcio s\xFAbito"
      IsCorrect: 1
    - SymptomName: Estado febril intermitente
      IsCorrect: 0
