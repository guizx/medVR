  Phrases:
  - PhraseSFX: {fileID: 8300000, guid: 57f8e92c2ca48bd43b155ac59fab3481, type: 3}
    Phrase: "Doutor, minhas costas doem sem parar, \xE9 uma dor profunda que parece
